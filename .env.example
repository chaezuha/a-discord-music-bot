# Copy this file to .env and fill in the values. Never commit .env.

# Required. Your bot token from https://discord.com/developers/applications
# (Your App -> Bot -> Reset Token)
DISCORD_TOKEN=

# Optional. A server (guild) ID for instant slash-command sync while developing.
# Right-click your server -> Copy Server ID (requires Developer Mode in Discord
# settings). Leave empty to sync commands globally, which can take up to an
# hour to show up in Discord.
DEV_GUILD_ID=

# Optional. Seconds of inactivity (nothing playing, empty queue) before the
# bot automatically leaves the voice channel. Defaults to 180 (3 minutes).
IDLE_TIMEOUT_SECONDS=180
