# Copy this file to .env and fill in the values. Never commit .env.

# Required. Your bot token from https://discord.com/developers/applications
# (Your App -> Bot -> Reset Token)
DISCORD_TOKEN=

# Optional. A server (guild) ID for instant slash-command sync while developing.
# Right-click your server -> Copy Server ID (requires Developer Mode in Discord
# settings). Leave empty to sync commands globally, which can take up to an
# hour to show up in Discord.
DEV_GUILD_ID=

# Optional. Seconds before the bot automatically leaves the voice channel,
# both when nothing is playing (empty queue) and when everyone else has left
# the channel. Defaults to 180 (3 minutes).
IDLE_TIMEOUT_SECONDS=180

# Optional. Your Discord user ID. If set, the bot DMs you (at most once per
# 24 hours) when repeated extraction failures suggest yt-dlp needs an update.
OWNER_ID=

# Optional. How many tracks /play imports when given a playlist or album URL.
# Defaults to 10; must be between 1 and 500.
PLAYLIST_MAX_TRACKS=10

# Optional. Directory for rotating log files (bot.log plus a crash-only
# faulthandler.log). Defaults to ./logs. If the directory can't be created or
# written (e.g. a read-only container without the logs volume), the bot logs
# to the console only.
LOG_DIR=

# Optional. If the bot stays disconnected from Discord longer than this many
# seconds, it exits so a supervisor can restart it with a fresh session (the
# fix for being stuck offline after e.g. a router restart). Defaults to 0
# (disabled) because a plain `python bot.py` run has nothing to restart it;
# compose.yaml turns it on with 300 since Docker's restart policy brings the
# bot back automatically.
WATCHDOG_DISCONNECT_SECONDS=

# Optional. Which sites direct /play URLs may point at. Unset: YouTube,
# SoundCloud, and Bandcamp (subdomains included). A comma-separated list of
# domains REPLACES those defaults, e.g. youtube.com,vimeo.com. Set to * to
# allow any yt-dlp-supported site — only on servers where you trust everyone,
# since URLs are fetched from inside your network.
ALLOWED_URL_DOMAINS=
